<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OpenSoundcoreWindows.DevicePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Spacing="24" Padding="24">
            <Grid RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Column="0" Spacing="12">
                        <FontIcon FontFamily="Segoe Fluent Icons" 
                                  Glyph="&#xe7f6;" 
                                  FontSize="36"
                                  Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                        <TextBlock x:Name="DeviceModelText" 
                                   Text="Life Q30" 
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!--
                    <Button Grid.Column="1" 
                            Click="RefreshStats_Click"
                            Style="{StaticResource AccentButtonStyle}"
                            ToolTipService.ToolTip="Refresh Stats">
                        <FontIcon Glyph="&#xE72C;" FontSize="16"/>
                    </Button>
                    -->

                    <Button Grid.Column="2" 
                            Click="DisconnectDevice_Click"
                            ToolTipService.ToolTip="Disconnect Device">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xe8bb;" FontSize="10"/>
                            <TextBlock>Disconnect</TextBlock>
                        </StackPanel>
                    </Button>
                </Grid>

                <Grid Grid.Row="1" ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock x:Name="ConnectionStatusText" 
                                   Text="Connected" 
                                   FontSize="13"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:Name="BatteryLevelText" 
               Text="--" 
               FontSize="15"
               FontWeight="SemiBold"
               VerticalAlignment="Center"/>
                            <FontIcon x:Name="BatteryIcon" 
              FontFamily="Segoe Fluent Icons" 
              Glyph="&#xe850;"
              FontSize="20"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>

            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

            <!-- Main Sound Modes (The "Pretty" Buttons) -->
            <StackPanel Spacing="16">
                <TextBlock Text="Sound Mode" 
                           FontSize="18"
                           FontWeight="SemiBold"/>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
        x:Name="NoiseCancelingButton"
Click="SoundMode_Click"
Tag="NoiseCanceling"
        HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xe74f;" FontSize="15"/>
                            <TextBlock Text="Noise Cancelling"/>
                        </StackPanel>
                    </Button>
                    <!--<Button Grid.Column="0"
                            x:Name="NoiseCancelingButton"
                            Click="SoundMode_Click"
                            Tag="NoiseCanceling"
                            HorizontalAlignment="Stretch"
                            Padding="16,24">
                        <StackPanel Spacing="12">
                            <FontIcon Glyph="&#xE74F;" FontSize="32"/>
                            <TextBlock Text="Noise Canceling" 
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Button>-->

                    <Button Grid.Column="1"
        x:Name="TransparencyButton"
Click="SoundMode_Click"
Tag="Transparency"
        HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xe767;" FontSize="15"/>
                            <TextBlock Text="Transparency"/>
                        </StackPanel>
                    </Button>
                    <!--<Button Grid.Column="1"
                            x:Name="TransparencyButton"
                            Click="SoundMode_Click"
                            Tag="Transparency"
                            HorizontalAlignment="Stretch"
                            Padding="16,24">
                        <StackPanel Spacing="12">
                            <FontIcon Glyph="&#xE767;" FontSize="32"/>
                            <TextBlock Text="Transparency" 
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Button>-->

                    <Button Grid.Column="2"
        x:Name="NormalButton"
Click="SoundMode_Click"
Tag="Normal"
        HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xf0ed;" FontSize="15"/>
                            <TextBlock Text="Normal"/>
                        </StackPanel>
                    </Button>
                    <!--<Button Grid.Column="2"
                            x:Name="NormalButton"
                            Click="SoundMode_Click"
                            Tag="Normal"
                            HorizontalAlignment="Stretch"
                            Padding="16,24">
                        <StackPanel Spacing="12">
                            <FontIcon Glyph="&#xE768;" FontSize="32"/>
                            <TextBlock Text="Normal" 
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Button>-->
                </Grid>
                <TextBlock x:Name="SoundModeStatusText" Visibility="Collapsed" Foreground="Red"/>
            </StackPanel>

            <!-- Noise Canceling Profiles (Animate visibility) -->
            <StackPanel x:Name="AncProfilesPanel" Spacing="16" Visibility="Collapsed" Opacity="0">
                <StackPanel.RenderTransform>
                    <TranslateTransform x:Name="AncTransform" Y="-10"/>
                </StackPanel.RenderTransform>
                <StackPanel.Resources>
                    <Storyboard x:Name="ShowAncProfiles">
                        <DoubleAnimation Storyboard.TargetName="AncProfilesPanel" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                        <DoubleAnimation Storyboard.TargetName="AncTransform" Storyboard.TargetProperty="Y" To="0" Duration="0:0:0.15">
                            <DoubleAnimation.EasingFunction>
                                <CircleEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                    <Storyboard x:Name="HideAncProfiles">
                        <DoubleAnimation Storyboard.TargetName="AncProfilesPanel" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                        <DoubleAnimation Storyboard.TargetName="AncTransform" Storyboard.TargetProperty="Y" To="-10" Duration="0:0:0.15"/>
                    </Storyboard>
                </StackPanel.Resources>

                <TextBlock Text="Noise Canceling Profile" 
                           FontSize="14"
                           FontWeight="Medium"/>

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            x:Name="AncTransportButton"
                            Click="AncProfile_Click"
                            Tag="Transport"
                            HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xe7c0;" FontSize="15"/>
                            <TextBlock Text="Transport"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="1"
                            x:Name="AncIndoorButton"
                            Click="AncProfile_Click"
                            Tag="Indoor"
                            HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xec06;" FontSize="15"/>
                            <TextBlock Text="Indoor"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2"
                            x:Name="AncOutdoorButton"
                            Click="AncProfile_Click"
                            Tag="Outdoor"
                            HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xec0a;" FontSize="15"/>
                            <TextBlock Text="Outdoor"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
