<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OpenSoundcoreWindows.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OpenSoundcoreWindows"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Spacing="16">
        <StackPanel Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="About Device"
               Style="{StaticResource SubtitleTextBlockStyle}"
               VerticalAlignment="Center"/>

                <Button Click="RefreshStats_Click"
            VerticalAlignment="Center"
            Padding="4"
            MinWidth="0"
            MinHeight="0">
                    <FontIcon Glyph="&#xE72C;" FontSize="12"/>
                </Button>
            </StackPanel>
            <TextBlock x:Name="DeviceModelText" Text="Model: N/A"/>
            <TextBlock x:Name="AmbientModeText" Text="Ambient Mode: N/A"/>
            <TextBlock x:Name="BatteryOverallText" Text="Battery: N/A"/>
            <TextBlock x:Name="BatteryLeftText" Text="Left Battery: N/A"/>
            <TextBlock x:Name="BatteryRightText" Text="Right Battery: N/A"/>
            <TextBlock x:Name="BatteryCaseText" Text="Case Battery: N/A"/>
            <TextBlock x:Name="ChargingText" Text="Charging: N/A"/>
        </StackPanel>
        <StackPanel Spacing="8">
            <TextBlock Text="About App"
Style="{StaticResource SubtitleTextBlockStyle}"
VerticalAlignment="Center"/>
                <TextBlock>
                    <Run Text="This app uses "/>
                    <Hyperlink NavigateUri="https://github.com/Oppzippy/OpenSCQ30">Oppzippy/OpenSCQ30</Hyperlink>
                    <Run Text=" to communicate to connected devices."/>
                </TextBlock>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
