<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="OpenSoundcoreWindows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OpenSoundcoreWindows"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="OpenSoundcoreWindows">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TitleBar
        x:Name="titleBar"
            Title="Lyra"
        Grid.Row="0"
        BackRequested="TitleBar_BackRequested"
        IsBackButtonEnabled="{x:Bind ContentFrame.CanGoBack, Mode=OneWay}"
            IsBackButtonVisible="{x:Bind ContentFrame.CanGoBack, Mode=OneWay}"
        IsPaneToggleButtonVisible="False"/>


        <NavigationView
        x:Name="NavView"
        Grid.Row="1"
        IsPaneVisible="False"
        IsPaneToggleButtonVisible="False"   
        IsBackButtonVisible="Collapsed"
        PaneTitle="Headphones"
        PaneDisplayMode="Left"
        SelectionChanged="NavView_SelectionChanged"
        IsSettingsVisible="False">

            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="deviceItem" Content="My Device" Tag="device">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xe7f6;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="aboutItem" Content="About" Tag="about">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xe946;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" Margin="24" />

        </NavigationView>
    </Grid>
</Window>
